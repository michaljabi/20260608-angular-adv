{
  "name": "auction-elements",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/auction-elements/src",
  "tags": ["type:app", "platform:web", "scope:elements"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/auction-elements",
        "browser": "apps/auction-elements/src/main.ts",
        "tsConfig": "apps/auction-elements/tsconfig.app.json",
        "index": false,
        "outputHashing": "none",
        "assets": [
          {
            "glob": "demo.html",
            "input": "apps/auction-elements/src",
            "output": "."
          }
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "demo": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "auction-elements:build",
        "staticFilePath": "dist/apps/auction-elements/browser",
        "port": 4300,
        "open": "/demo.html"
      }
    }
  }
}
